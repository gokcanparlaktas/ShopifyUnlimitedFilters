{% schema %}
{
  "name": "Unlimited Filters",
  
  "target": "section", 
  "templates": ["collection"],
  "stylesheet": "unlimited-filters.css",
  "javascript": "unlimited-filters-embed.js",
  "settings": [
    {
      "type": "text",
      "id": "storefront_token",
      "label": "Storefront token"
    },
    {
      "type": "checkbox",
      "id": "hide_native_grid",
      "label": "Hide theme product grid",
      "default": false
    },
    {
      "type": "range",
      "id": "col_mobile",
      "label": "Mobile columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "col_tablet",
      "label": "Tablet columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "col_desktop",
      "label": "Desktop columns",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 0
    }
  ]
}
{% endschema %}

{% if request.page_type == 'collection' and collection %}
  <div id="uf-mount-{{ block.id }}"></div>
  <script>
    window.UnlimitedFiltersConfig = {
      shopDomain: {{ shop.permanent_domain | json }},
      storefrontToken: {{ block.settings.storefront_token | json }},
      collectionHandle: {{ collection.handle | json }},
      appBaseUrl: "https://shopify-unlimited-filters.vercel.app",
      colMobile: {{ block.settings.col_mobile | json }},
      colTablet: {{ block.settings.col_tablet | json }},
      colDesktop: {{ block.settings.col_desktop | json }},
      sidePadding: {{ block.settings.side_padding | json }},
      mountId: {{ 'uf-mount-' | append: block.id | json }},
      hideNativeGrid: {{ block.settings.hide_native_grid | json }}
    };
  </script>
{% endif %}